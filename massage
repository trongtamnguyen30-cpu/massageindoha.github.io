<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Doha Luxury Massage</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f8f8f8;
}

/* HEADER */
header {
    background: #111;
    color: white;
    padding: 20px;
    text-align: center;
}

/* NAV */
nav {
    display: flex;
    justify-content: center;
    background: #222;
}

nav a {
    color: white;
    padding: 15px 20px;
    text-decoration: none;
}

nav a:hover {
    background: #ff5e8a;
}

/* HERO */
.hero {
    background: url('https://images.unsplash.com/photo-1544161515-4ab6ce6db874') center/cover;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 40px;
    font-weight: bold;
}

/* SECTION */
section {
    padding: 40px;
    text-align: center;
}

/* SERVICES */
.services {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
    gap: 20px;
}

.card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
}

/* GALLERY */
.gallery img {
    width: 100%;
    border-radius: 10px;
}

/* BUTTONS */
.btn {
    display: inline-block;
    padding: 12px 20px;
    background: #ff5e8a;
    color: white;
    text-decoration: none;
    border-radius: 8px;
    margin: 10px;
}

/* FOOTER */
footer {
    background: #111;
    color: white;
    text-align: center;
    padding: 20px;
}
</style>
</head>

<body>

<header>
    <h1>Doha Luxury Massage</h1>
    <p>Relax • Refresh • Rejuvenate</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#services">Services</a>
    <a href="#gallery">Gallery</a>
    <a href="#contact">Contact</a>
</nav>

<div class="hero">
    Premium Massage in Doha
</div>

<section id="services">
    <h2>Our Services</h2>
    <div class="services">

        <div class="card">
            <h3>Swedish Massage</h3>
            <p>Relaxing full-body massage to reduce stress.</p>
        </div>

        <div class="card">
            <h3>Deep Tissue Massage</h3>
            <p>Relieves muscle tension and chronic pain.</p>
        </div>

        <div class="card">
            <h3>Thai Massage</h3>
            <p>Traditional stretching and pressure techniques.</p>
        </div>

        <div class="card">
            <h3>Aromatherapy Massage</h3>
            <p>Essential oils for deep relaxation.</p>
        </div>

        <div class="card">
            <h3>Hot Stone Massage</h3>
            <p>Warm stones to improve blood circulation.</p>
        </div>

        <div class="card">
            <h3>VIP Luxury Massage</h3>
            <p>Premium experience with private room & special care.</p>
        </div>

    </div>

    <a class="btn" href="#booking">Book Now</a>
</section>

<section id="gallery">
    <h2>Our Team</h2>
    <div class="services gallery">

        <!-- Bạn thay bằng ảnh của bạn -->
        <img src="image1.jpg">
        <img src="image2.jpg">
        <img src="image3.jpg">

    </div>
</section>

<section id="booking">
    <h2>Book Appointment</h2>
    <p>Click below to book instantly via WhatsApp</p>

    <a class="btn" href="https://wa.me/84866257896" target="_blank">
        Book via WhatsApp
    </a>
</section>

<section id="contact">
    <h2>Contact Us</h2>
    <p>📍 Location: Doha, Qatar</p>
    <p>📞 WhatsApp: +84866257896</p>
</section>

<footer>
    <p>© 2026 Doha Luxury Massage. All rights reserved.</p>
</footer>

</body>
</html>
